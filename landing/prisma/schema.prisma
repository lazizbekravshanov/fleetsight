generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  String              @id @default(cuid())
  email               String              @unique
  passwordHash        String
  failedLoginAttempts Int                 @default(0)
  lockoutUntil        DateTime?
  createdAt           DateTime            @default(now())
  profile             CustomerProfile?
  apiTokens           ApiToken[]
  watchedCarriers     WatchedCarrier[]
  searchHistory       SearchHistory[]
  carrierNotes        CarrierNote[]
  monitoredRosters    MonitoredRoster[]
  monitoringAlerts    MonitoringAlert[]
  communityReports    CommunityReport[]
  teamMemberships     TeamMember[]

  @@index([createdAt])
}

// ── Team / Multi-user Workspaces ────────────────────────────────

model Team {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  members     TeamMember[]
  sharedWatchlist TeamWatchedCarrier[]
  sharedNotes    TeamNote[]

  @@index([slug])
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  role      String   @default("member")
  joinedAt  DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
}

model TeamWatchedCarrier {
  id              String    @id @default(cuid())
  teamId          String
  dotNumber       String
  legalName       String
  addedByUserId   String
  lastCheckedAt   DateTime?
  statusChanged   Boolean   @default(false)
  addedAt         DateTime  @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, dotNumber])
  @@index([teamId])
}

model TeamNote {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  dotNumber String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId, dotNumber])
}

model CarrierNote {
  id        String   @id @default(cuid())
  userId    String
  dotNumber String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dotNumber])
}

model WatchedCarrier {
  id              String    @id @default(cuid())
  userId          String
  dotNumber       String
  legalName       String
  lastUsdotStatus String?
  lastAuthStatus  String?
  lastCheckedAt   DateTime?
  statusChanged   Boolean   @default(false)
  addedAt         DateTime  @default(now())
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dotNumber])
  @@index([userId])
}

model SearchHistory {
  id         String   @id @default(cuid())
  userId     String
  dotNumber  String
  legalName  String
  searchedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, searchedAt])
}


model CustomerProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  companyName String
  usdotNumber String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([usdotNumber])
}

model ApiToken {
  id        String        @id @default(cuid())
  userId    String
  tokenHash String        @unique
  scope     String
  tier      String        @default("free")
  createdAt DateTime      @default(now())
  expiresAt DateTime
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  usageLogs ApiKeyUsage[]

  @@index([userId])
  @@index([expiresAt])
}

model WebhookEvent {
  id          String   @id @default(cuid())
  source      String
  type        String
  payloadJson String
  createdAt   DateTime @default(now())

  @@index([source, type])
  @@index([createdAt])
}

// ── Chameleon Carrier Detection ─────────────────────────────────

model FmcsaCarrier {
  id               String    @id @default(cuid())
  dotNumber        Int       @unique
  legalName        String
  dbaName          String?
  phyStreet        String?
  phyCity          String?
  phyState         String?
  phyZip           String?
  phone            String?
  fax              String?
  cellPhone        String?
  companyOfficer1  String?
  companyOfficer2  String?
  statusCode       String?
  priorRevokeFlag  String?
  priorRevokeDot   Int?
  addDate          DateTime?
  powerUnits       Int?
  totalDrivers     Int?
  fleetSize        String?
  docketPrefix     String?
  docketNumber     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  crashes     FmcsaCrash[]
  inspections FmcsaInspection[]
  riskScore   CarrierRiskScore?
  clusterMemberships ClusterMember[]
  carrierVehicles    CarrierVehicle[]

  @@index([phone])
  @@index([phyStreet, phyCity, phyState])
  @@index([companyOfficer1])
  @@index([priorRevokeFlag])
}

model FmcsaCrash {
  id           String   @id @default(cuid())
  dotNumber    Int
  reportDate   DateTime?
  reportNumber String?
  state        String?
  fatalities   Int      @default(0)
  injuries     Int      @default(0)
  towAway      Boolean  @default(false)
  createdAt    DateTime @default(now())

  carrier FmcsaCarrier @relation(fields: [dotNumber], references: [dotNumber], onDelete: Cascade)

  @@index([dotNumber])
}

model FmcsaInspection {
  id              String    @id @default(cuid())
  dotNumber       Int
  inspectionDate  DateTime?
  vin             String?
  state           String?
  vehicleOosTotal Int       @default(0)
  driverOosTotal  Int       @default(0)
  createdAt       DateTime  @default(now())

  carrier FmcsaCarrier @relation(fields: [dotNumber], references: [dotNumber], onDelete: Cascade)

  @@index([dotNumber])
  @@index([vin])
}

model CarrierLink {
  id         String @id @default(cuid())
  dotNumberA Int
  dotNumberB Int
  score      Float
  reasonsJson String
  runId      String

  @@index([dotNumberA])
  @@index([dotNumberB])
  @@index([score])
  @@unique([dotNumberA, dotNumberB, runId])
}

model CarrierCluster {
  id           String  @id @default(cuid())
  clusterId    String
  size         Int
  edgeCount    Int
  avgLinkScore Float
  maxLinkScore Float
  runId        String

  members ClusterMember[]

  @@unique([clusterId, runId])
}

model ClusterMember {
  id        String @id @default(cuid())
  clusterId String
  dotNumber Int

  cluster CarrierCluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  carrier FmcsaCarrier   @relation(fields: [dotNumber], references: [dotNumber], onDelete: Cascade)

  @@unique([clusterId, dotNumber])
  @@index([dotNumber])
}

model CarrierRiskScore {
  id             String @id @default(cuid())
  dotNumber      Int    @unique
  chameleonScore Float
  safetyScore    Float
  compositeScore Float
  signalsJson    String
  clusterSize    Int    @default(0)
  updatedAt      DateTime @updatedAt

  carrier FmcsaCarrier @relation(fields: [dotNumber], references: [dotNumber], onDelete: Cascade)

  @@index([compositeScore])
}

model SyncRun {
  id            String   @id @default(cuid())
  runId         String   @unique
  dataset       String
  status        String   @default("running")
  rowsProcessed Int      @default(0)
  errorMessage  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ── Shared VIN & Carrier Affiliation Detection ─────────────────

model VinObservation {
  id             String    @id @default(cuid())
  vin            String
  dotNumber      Int
  inspectionDate DateTime
  inspectionId   String?
  state          String?
  vehicleType    String    @default("TRUCK")
  unitMake       String?
  unitYear       Int?
  licensePlate   String?
  licenseState   String?
  source         String    @default("MCMIS")
  ingestedAt     DateTime  @default(now())

  @@unique([vin, dotNumber, inspectionDate])
  @@index([vin])
  @@index([dotNumber])
  @@index([inspectionDate])
  @@index([vin, dotNumber])
}

model Vehicle {
  id          String   @id @default(cuid())
  vin         String   @unique
  make        String?
  model       String?
  modelYear   Int?
  bodyClass   String?
  vehicleType String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  carrierVehicles CarrierVehicle[]

  @@index([make])
  @@index([modelYear])
}

model CarrierVehicle {
  id              String    @id @default(cuid())
  dotNumber       Int
  vin             String
  unitType        String    @default("TRUCK")
  observationCount Int      @default(1)
  firstSeenAt     DateTime  @default(now())
  lastSeenAt      DateTime  @default(now())
  source          String    @default("inspection")
  createdAt       DateTime  @default(now())

  carrier     FmcsaCarrier? @relation(fields: [dotNumber], references: [dotNumber], onDelete: Cascade)
  vehicle     Vehicle       @relation(fields: [vin], references: [vin], onDelete: Cascade)

  @@unique([dotNumber, vin])
  @@index([dotNumber])
  @@index([vin])
}

model CarrierAffiliation {
  id               String   @id @default(cuid())
  clusterId        String?
  dotNumberA       Int
  dotNumberB       Int
  sharedVinCount   Int
  affiliationScore Float
  affiliationType  String   @default("UNKNOWN")
  sharedVinsJson   String   @default("[]")
  sigVinRatio      Float    @default(0)
  sigTemporal      Float    @default(0)
  sigConcurrent    Float    @default(0)
  sigAddress       Float    @default(0)
  sigName          Float    @default(0)
  sigOosReincarnation Float @default(0)
  sigFleetAbsorption  Float @default(0)
  reasonsJson      String   @default("[]")
  firstDetectedAt  DateTime @default(now())
  lastUpdatedAt    DateTime @updatedAt
  flagged          Boolean  @default(false)
  notes            String?

  edgeVins AffiliationEdgeVin[]

  @@unique([dotNumberA, dotNumberB])
  @@index([dotNumberA])
  @@index([dotNumberB])
  @@index([affiliationScore])
  @@index([affiliationType])
  @@index([clusterId])
}

model AffiliationEdgeVin {
  id                 String   @id @default(cuid())
  edgeId             String
  vin                String
  vehicleType        String?
  unitMake           String?
  unitYear           Int?
  dotAFirstSeen      DateTime?
  dotALastSeen       DateTime?
  dotBFirstSeen      DateTime?
  dotBLastSeen       DateTime?
  overlapDays        Int      @default(0)
  gapDays            Int      @default(0)
  transferDirection  String   @default("UNCLEAR")

  edge CarrierAffiliation @relation(fields: [edgeId], references: [id], onDelete: Cascade)

  @@unique([edgeId, vin])
  @@index([edgeId])
}

model AffiliationCluster {
  id          String   @id @default(cuid())
  clusterId   String   @unique
  memberCount Int
  dotNumbers  String
  maxScore    Float    @default(0)
  worstType   String   @default("UNKNOWN")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── Freight Identity Graph ───────────────────────────────────────

model DriverObservation {
  id             String   @id @default(cuid())
  cdlNumber      String
  cdlState       String
  cdlKey         String
  driverName     String?
  dotNumber      Int
  inspectionDate DateTime
  inspectionId   String?
  state          String?
  source         String   @default("MCMIS")
  ingestedAt     DateTime @default(now())

  @@unique([cdlKey, dotNumber, inspectionDate])
  @@index([cdlKey])
  @@index([dotNumber])
}

model CarrierAddress {
  id          String @id @default(cuid())
  dotNumber   Int
  addressType String
  rawAddress  String
  normalized  String
  city        String?
  state       String?
  zip         String?
  lat         Float?
  lng         Float?
  geohash     String?

  @@index([normalized])
  @@index([dotNumber])
  @@index([geohash])
  @@index([city, state])
}

model CarrierPrincipal {
  id             String    @id @default(cuid())
  dotNumber      Int
  principalName  String
  nameNormalized String
  title          String?
  sourceDate     DateTime?

  @@index([nameNormalized])
  @@index([dotNumber])
}

model CarrierAgent {
  id              String    @id @default(cuid())
  dotNumber       Int
  agentType       String
  agentName       String
  agentNormalized String
  agentAddress    String?
  effectiveDate   DateTime?
  source          String    @default("FMCSA_LI")

  @@index([agentNormalized])
  @@index([dotNumber])
}

model CarrierInsuranceRecord {
  id              String    @id @default(cuid())
  dotNumber       Int
  insuranceType   String?
  insurerName     String?
  policyNumber    String?
  coverageAmount  Int?
  effectiveDate   DateTime?
  expirationDate  DateTime?
  status          String?
  lapseCount      Int       @default(0)
  source          String    @default("FMCSA_LI")

  @@index([dotNumber])
  @@index([insurerName])
  @@index([status])
}

model CarrierTrustScore {
  id             String   @id @default(cuid())
  dotNumber      Int      @unique
  overallScore   Int
  grade          String
  identity       Int      @default(0)
  safety         Int      @default(0)
  insurance      Int      @default(0)
  network        Int      @default(0)
  operational    Int      @default(0)
  compliance     Int      @default(0)
  financial      Int      @default(0)
  flagsJson      String   @default("[]")
  clusterSize    Int      @default(0)
  clusterAvgScore Float   @default(0)
  oosProb90d     Float?
  trend          String   @default("STABLE")
  updatedAt      DateTime @updatedAt

  @@index([overallScore])
  @@index([grade])
}

// ── Continuous Monitoring (rosters, alerts) ─────────────────────

model MonitoredRoster {
  id        String          @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  carriers  RosterCarrier[]

  @@index([userId])
}

model RosterCarrier {
  id            String          @id @default(cuid())
  rosterId      String
  dotNumber     String
  legalName     String
  healthStatus  String          @default("unknown")
  lastGrade     String?
  lastScore     Int?
  lastCheckedAt DateTime?
  createdAt     DateTime        @default(now())
  roster        MonitoredRoster @relation(fields: [rosterId], references: [id], onDelete: Cascade)

  @@unique([rosterId, dotNumber])
  @@index([rosterId])
}

model MonitoringAlert {
  id            String    @id @default(cuid())
  userId        String
  dotNumber     String
  legalName     String
  alertType     String
  severity      String
  title         String
  detail        String
  previousValue String?
  newValue      String?
  readAt        DateTime?
  createdAt     DateTime  @default(now())
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

// ── Community Risk Reports ──────────────────────────────────────

model CommunityReport {
  id          String   @id @default(cuid())
  userId      String
  dotNumber   String
  reportType  String
  description String
  severity    String
  status      String   @default("active")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([dotNumber, createdAt])
  @@index([dotNumber, status])
  @@index([userId, dotNumber, reportType])
}

model CommunityReportSummary {
  dotNumber       String   @id @unique
  totalReports12m Int      @default(0)
  reportsByType   String   @default("{}")
  communityScore  Int      @default(0)
  isFlagged       Boolean  @default(false)
  lastReportAt    DateTime?
  updatedAt       DateTime @updatedAt
}

// ── API Key Usage Tracking ──────────────────────────────────────

model ApiKeyUsage {
  id        String   @id @default(cuid())
  tokenId   String
  endpoint  String
  dotNumber String?
  createdAt DateTime @default(now())
  token     ApiToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)

  @@index([tokenId, createdAt])
}

// ── Inspection Violations & Carrier Intelligence ─────────────

model InspectionViolation {
  id                String   @id @default(cuid())
  inspectionId      String
  dotNumber         Int
  vinClean          String?
  cdlKey            String?
  inspectionDate    DateTime
  inspectionLevel   Int?
  inspectionState   String?
  inspectionFacility String?

  violationCode     String
  violationGroup    String?
  violationDescription String?
  oosViolation      Boolean  @default(false)
  violationSeverity String?

  source            String   @default("MCMIS")
  ingestedAt        DateTime @default(now())

  @@unique([inspectionId, violationCode])
  @@index([dotNumber])
  @@index([vinClean])
  @@index([cdlKey])
  @@index([violationCode])
  @@index([violationGroup])
  @@index([inspectionDate])
  @@index([inspectionFacility])
}

model ViolationCode {
  id          String @id @default(cuid())
  code        String @unique
  groupName   String
  section     String
  description String
  severity    String   @default("other")
  fixAction   String?
  checkItem   String?

  @@index([groupName])
}

// ── Enabler Network ─────────────────────────────────────────

model Enabler {
  id                    String   @id @default(cuid())
  enablerType           String
  name                  String
  nameNormalized        String
  address               String?
  addressNormalized     String?
  city                  String?
  state                 String?
  zip                   String?
  phone                 String?
  phoneNormalized       String?
  lat                   Float?
  lng                   Float?

  clientCount           Int      @default(0)
  activeClientCount     Int      @default(0)
  oosClientCount        Int      @default(0)
  chameleonClientCount  Int      @default(0)
  avgClientLifespanDays Int?
  riskScore             Float    @default(0)
  riskTier              String?

  firstSeenAt           DateTime?
  lastSeenAt            DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  carrierLinks EnablerCarrierLink[]

  @@index([nameNormalized])
  @@index([enablerType])
  @@index([riskScore])
  @@index([phoneNormalized])
}

model EnablerCarrierLink {
  id              String    @id @default(cuid())
  enablerId       String
  dotNumber       String
  relationship    String
  effectiveDate   DateTime?
  terminationDate DateTime?
  isCurrent       Boolean   @default(true)
  source          String

  createdAt       DateTime  @default(now())

  enabler Enabler @relation(fields: [enablerId], references: [id], onDelete: Cascade)

  @@unique([enablerId, dotNumber, relationship])
  @@index([enablerId])
  @@index([dotNumber])
  @@index([isCurrent])
}

// ── Agentic AI: sessions, runs, tool calls, artifacts, memory ───

model AgentSession {
  id               String         @id @default(cuid())
  userId           String
  carrierDotNumber String?
  persona          String         @default("investigator")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  runs             AgentRun[]
  messages         AgentMessage[]
  artifacts        Artifact[]

  @@unique([userId, carrierDotNumber])
  @@index([userId])
  @@index([carrierDotNumber])
}

model AgentRun {
  id          String         @id @default(cuid())
  sessionId   String
  kind        String         // "auto_brief" | "user_turn" | "watchdog" | "scheduled" | "persona_switch"
  persona     String
  status      String         @default("running") // "running" | "complete" | "error" | "aborted"
  triggeredBy String         @default("user")    // "user" | "cron" | "system"
  tokensIn    Int            @default(0)
  tokensOut   Int            @default(0)
  error       String?
  createdAt   DateTime       @default(now())
  completedAt DateTime?
  session     AgentSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  toolCalls   ToolCall[]
  messages    AgentMessage[]
  artifacts   Artifact[]

  @@index([sessionId])
  @@index([status])
}

model AgentMessage {
  id        String       @id @default(cuid())
  sessionId String
  runId     String?
  role      String       // "user" | "assistant"
  content   String       // JSON-stringified Anthropic content array
  createdAt DateTime     @default(now())
  session   AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  run       AgentRun?    @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@index([sessionId, createdAt])
}

model ToolCall {
  id         String   @id @default(cuid())
  runId      String
  toolUseId  String   // Anthropic tool_use block id
  name       String
  input      String   // JSON
  output     String?  // JSON
  summary    String   // <=200 char one-liner shown in tool feed
  ok         Boolean  @default(true)
  durationMs Int
  createdAt  DateTime @default(now())
  run        AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, toolUseId])
  @@index([runId])
  @@index([name])
}

model Artifact {
  id        String       @id @default(cuid())
  sessionId String
  runId     String
  type      String       // "decision_card" | "memo" | "evidence_list" | "chameleon_graph" | "comparison" | "timeline"
  title     String?
  payload   String       // JSON
  citations String       // JSON array of toolUseIds
  createdAt DateTime     @default(now())
  session   AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  run       AgentRun     @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([runId])
}

model AgentMemory {
  id               String   @id @default(cuid())
  userId           String?  // null = applies to any user (carrier-scoped fact)
  carrierDotNumber String?  // null = applies to any carrier (user-scoped pref)
  kind             String   // "observation" | "preference" | "context"
  content          String
  sourceRunId      String?
  createdAt        DateTime @default(now())

  @@index([carrierDotNumber, kind])
  @@index([userId, kind])
}

model CarrierVerdictCache {
  dotNumber        String   @id
  verdict          String   // "pass" | "watch" | "fail"
  headline         String
  bullets          String   // JSON array
  confidence       Float
  generatedAt      DateTime @default(now())
  generatedByRunId String?

  @@index([generatedAt])
}

model Case {
  id        String    @id @default(cuid())
  userId    String
  dotNumber String
  kind      String    // "investigation" | "monitoring"
  title     String
  status    String    @default("open") // "open" | "watching" | "resolved" | "closed"
  verdict   String?
  openedAt  DateTime  @default(now())
  closedAt  DateTime?
  sessionId String?

  @@index([userId, status])
  @@index([dotNumber])
}

model ScheduledAgentRun {
  id          String   @id @default(cuid())
  userId      String
  dotNumber   String
  persona     String   @default("investigator")
  question    String
  scheduledAt DateTime
  status      String   @default("pending") // "pending" | "running" | "complete" | "error"
  runId       String?
  createdAt   DateTime @default(now())

  @@index([scheduledAt, status])
  @@index([userId])
}

/// Idempotency tracking for action tools (watch_carrier, add_note, flag_for_review).
/// When the runtime catches an error after a successful DB write, the user re-runs,
/// and the model retries the same logical action — this table makes the retry a no-op
/// by mapping (runId, toolUseId) → the resource that was created the first time.
model IdempotencyKey {
  id           String   @id @default(cuid())
  runId        String
  toolUseId    String
  resourceType String   // "carrier_note" | "monitoring_alert" | "watched_carrier" | "case"
  resourceId   String
  createdAt    DateTime @default(now())

  @@unique([runId, toolUseId, resourceType])
  @@index([runId])
}
