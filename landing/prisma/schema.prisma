generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String              @id @default(cuid())
  email               String              @unique
  passwordHash        String
  failedLoginAttempts Int                 @default(0)
  lockoutUntil        DateTime?
  createdAt           DateTime            @default(now())
  profile             CustomerProfile?
  apiTokens           ApiToken[]
  creditBalance       CreditBalance?
  creditTransactions  CreditTransaction[]
  stripeCustomer      StripeCustomer?
  creditPurchases     CreditPurchase[]
  watchedCarriers     WatchedCarrier[]
  searchHistory       SearchHistory[]
  carrierNotes        CarrierNote[]
  subscription        Subscription?
  monitoredRosters    MonitoredRoster[]
  monitoringAlerts    MonitoringAlert[]
  communityReports    CommunityReport[]

  @@index([createdAt])
}

model CarrierNote {
  id        String   @id @default(cuid())
  userId    String
  dotNumber String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dotNumber])
}

model WatchedCarrier {
  id              String    @id @default(cuid())
  userId          String
  dotNumber       String
  legalName       String
  lastUsdotStatus String?
  lastAuthStatus  String?
  lastCheckedAt   DateTime?
  statusChanged   Boolean   @default(false)
  addedAt         DateTime  @default(now())
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dotNumber])
  @@index([userId])
}

model SearchHistory {
  id         String   @id @default(cuid())
  userId     String
  dotNumber  String
  legalName  String
  searchedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, searchedAt])
}

model CreditBalance {
  id        String   @id @default(cuid())
  userId    String   @unique
  credits   Int      @default(0)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CreditTransaction {
  id           String   @id @default(cuid())
  userId       String
  amount       Int
  type         String
  balanceAfter Int
  reference    String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model StripeCustomer {
  id               String @id @default(cuid())
  userId           String @unique
  stripeCustomerId String @unique
  user             User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CreditPurchase {
  id                      String   @id @default(cuid())
  userId                  String
  stripeCheckoutSessionId String   @unique
  stripePaymentIntentId   String?
  packCredits             Int
  packPriceCents          Int
  status                  String   @default("completed")
  createdAt               DateTime @default(now())
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CustomerProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  companyName String
  usdotNumber String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([usdotNumber])
}

model ApiToken {
  id        String        @id @default(cuid())
  userId    String
  tokenHash String        @unique
  scope     String
  tier      String        @default("free")
  createdAt DateTime      @default(now())
  expiresAt DateTime
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  usageLogs ApiKeyUsage[]

  @@index([userId])
  @@index([expiresAt])
}

model WebhookEvent {
  id          String   @id @default(cuid())
  source      String
  type        String
  payloadJson String
  createdAt   DateTime @default(now())

  @@index([source, type])
  @@index([createdAt])
}

// ── Chameleon Carrier Detection ─────────────────────────────────

model FmcsaCarrier {
  id               String    @id @default(cuid())
  dotNumber        Int       @unique
  legalName        String
  dbaName          String?
  phyStreet        String?
  phyCity          String?
  phyState         String?
  phyZip           String?
  phone            String?
  fax              String?
  cellPhone        String?
  companyOfficer1  String?
  companyOfficer2  String?
  statusCode       String?
  priorRevokeFlag  String?
  priorRevokeDot   Int?
  addDate          DateTime?
  powerUnits       Int?
  totalDrivers     Int?
  fleetSize        String?
  docketPrefix     String?
  docketNumber     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  crashes     FmcsaCrash[]
  inspections FmcsaInspection[]
  riskScore   CarrierRiskScore?
  clusterMemberships ClusterMember[]
  carrierVehicles    CarrierVehicle[]

  @@index([phone])
  @@index([phyStreet, phyCity, phyState])
  @@index([companyOfficer1])
  @@index([priorRevokeFlag])
}

model FmcsaCrash {
  id           String   @id @default(cuid())
  dotNumber    Int
  reportDate   DateTime?
  reportNumber String?
  state        String?
  fatalities   Int      @default(0)
  injuries     Int      @default(0)
  towAway      Boolean  @default(false)
  createdAt    DateTime @default(now())

  carrier FmcsaCarrier @relation(fields: [dotNumber], references: [dotNumber], onDelete: Cascade)

  @@index([dotNumber])
}

model FmcsaInspection {
  id              String    @id @default(cuid())
  dotNumber       Int
  inspectionDate  DateTime?
  vin             String?
  state           String?
  vehicleOosTotal Int       @default(0)
  driverOosTotal  Int       @default(0)
  createdAt       DateTime  @default(now())

  carrier FmcsaCarrier @relation(fields: [dotNumber], references: [dotNumber], onDelete: Cascade)

  @@index([dotNumber])
  @@index([vin])
}

model CarrierLink {
  id         String @id @default(cuid())
  dotNumberA Int
  dotNumberB Int
  score      Float
  reasonsJson String
  runId      String

  @@index([dotNumberA])
  @@index([dotNumberB])
  @@index([score])
  @@unique([dotNumberA, dotNumberB, runId])
}

model CarrierCluster {
  id           String  @id @default(cuid())
  clusterId    String
  size         Int
  edgeCount    Int
  avgLinkScore Float
  maxLinkScore Float
  runId        String

  members ClusterMember[]

  @@unique([clusterId, runId])
}

model ClusterMember {
  id        String @id @default(cuid())
  clusterId String
  dotNumber Int

  cluster CarrierCluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  carrier FmcsaCarrier   @relation(fields: [dotNumber], references: [dotNumber], onDelete: Cascade)

  @@unique([clusterId, dotNumber])
  @@index([dotNumber])
}

model CarrierRiskScore {
  id             String @id @default(cuid())
  dotNumber      Int    @unique
  chameleonScore Float
  safetyScore    Float
  compositeScore Float
  signalsJson    String
  clusterSize    Int    @default(0)
  updatedAt      DateTime @updatedAt

  carrier FmcsaCarrier @relation(fields: [dotNumber], references: [dotNumber], onDelete: Cascade)

  @@index([compositeScore])
}

model SyncRun {
  id            String   @id @default(cuid())
  runId         String   @unique
  dataset       String
  status        String   @default("running")
  rowsProcessed Int      @default(0)
  errorMessage  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ── Shared VIN & Carrier Affiliation Detection ─────────────────

model VinObservation {
  id             String    @id @default(cuid())
  vin            String
  dotNumber      Int
  inspectionDate DateTime
  inspectionId   String?
  state          String?
  vehicleType    String    @default("TRUCK")
  unitMake       String?
  unitYear       Int?
  licensePlate   String?
  licenseState   String?
  source         String    @default("MCMIS")
  ingestedAt     DateTime  @default(now())

  @@unique([vin, dotNumber, inspectionDate])
  @@index([vin])
  @@index([dotNumber])
  @@index([inspectionDate])
  @@index([vin, dotNumber])
}

model Vehicle {
  id          String   @id @default(cuid())
  vin         String   @unique
  make        String?
  model       String?
  modelYear   Int?
  bodyClass   String?
  vehicleType String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  carrierVehicles CarrierVehicle[]

  @@index([make])
  @@index([modelYear])
}

model CarrierVehicle {
  id              String    @id @default(cuid())
  dotNumber       Int
  vin             String
  unitType        String    @default("TRUCK")
  observationCount Int      @default(1)
  firstSeenAt     DateTime  @default(now())
  lastSeenAt      DateTime  @default(now())
  source          String    @default("inspection")
  createdAt       DateTime  @default(now())

  carrier     FmcsaCarrier? @relation(fields: [dotNumber], references: [dotNumber], onDelete: Cascade)
  vehicle     Vehicle       @relation(fields: [vin], references: [vin], onDelete: Cascade)

  @@unique([dotNumber, vin])
  @@index([dotNumber])
  @@index([vin])
}

model CarrierAffiliation {
  id               String   @id @default(cuid())
  clusterId        String?
  dotNumberA       Int
  dotNumberB       Int
  sharedVinCount   Int
  affiliationScore Float
  affiliationType  String   @default("UNKNOWN")
  sharedVinsJson   String   @default("[]")
  sigVinRatio      Float    @default(0)
  sigTemporal      Float    @default(0)
  sigConcurrent    Float    @default(0)
  sigAddress       Float    @default(0)
  sigName          Float    @default(0)
  sigOosReincarnation Float @default(0)
  sigFleetAbsorption  Float @default(0)
  reasonsJson      String   @default("[]")
  firstDetectedAt  DateTime @default(now())
  lastUpdatedAt    DateTime @updatedAt
  flagged          Boolean  @default(false)
  notes            String?

  edgeVins AffiliationEdgeVin[]

  @@unique([dotNumberA, dotNumberB])
  @@index([dotNumberA])
  @@index([dotNumberB])
  @@index([affiliationScore])
  @@index([affiliationType])
  @@index([clusterId])
}

model AffiliationEdgeVin {
  id                 String   @id @default(cuid())
  edgeId             String
  vin                String
  vehicleType        String?
  unitMake           String?
  unitYear           Int?
  dotAFirstSeen      DateTime?
  dotALastSeen       DateTime?
  dotBFirstSeen      DateTime?
  dotBLastSeen       DateTime?
  overlapDays        Int      @default(0)
  gapDays            Int      @default(0)
  transferDirection  String   @default("UNCLEAR")

  edge CarrierAffiliation @relation(fields: [edgeId], references: [id], onDelete: Cascade)

  @@unique([edgeId, vin])
  @@index([edgeId])
}

model AffiliationCluster {
  id          String   @id @default(cuid())
  clusterId   String   @unique
  memberCount Int
  dotNumbers  String
  maxScore    Float    @default(0)
  worstType   String   @default("UNKNOWN")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── Freight Identity Graph ───────────────────────────────────────

model DriverObservation {
  id             String   @id @default(cuid())
  cdlNumber      String
  cdlState       String
  cdlKey         String
  driverName     String?
  dotNumber      Int
  inspectionDate DateTime
  inspectionId   String?
  state          String?
  source         String   @default("MCMIS")
  ingestedAt     DateTime @default(now())

  @@unique([cdlKey, dotNumber, inspectionDate])
  @@index([cdlKey])
  @@index([dotNumber])
}

model CarrierAddress {
  id          String @id @default(cuid())
  dotNumber   Int
  addressType String
  rawAddress  String
  normalized  String
  city        String?
  state       String?
  zip         String?
  lat         Float?
  lng         Float?
  geohash     String?

  @@index([normalized])
  @@index([dotNumber])
  @@index([geohash])
  @@index([city, state])
}

model CarrierPrincipal {
  id             String    @id @default(cuid())
  dotNumber      Int
  principalName  String
  nameNormalized String
  title          String?
  sourceDate     DateTime?

  @@index([nameNormalized])
  @@index([dotNumber])
}

model CarrierAgent {
  id              String    @id @default(cuid())
  dotNumber       Int
  agentType       String
  agentName       String
  agentNormalized String
  agentAddress    String?
  effectiveDate   DateTime?
  source          String    @default("FMCSA_LI")

  @@index([agentNormalized])
  @@index([dotNumber])
}

model CarrierInsuranceRecord {
  id              String    @id @default(cuid())
  dotNumber       Int
  insuranceType   String?
  insurerName     String?
  policyNumber    String?
  coverageAmount  BigInt?
  effectiveDate   DateTime?
  expirationDate  DateTime?
  status          String?
  lapseCount      Int       @default(0)
  source          String    @default("FMCSA_LI")

  @@index([dotNumber])
  @@index([insurerName])
  @@index([status])
}

model CarrierTrustScore {
  id             String   @id @default(cuid())
  dotNumber      Int      @unique
  overallScore   Int
  grade          String
  identity       Int      @default(0)
  safety         Int      @default(0)
  insurance      Int      @default(0)
  network        Int      @default(0)
  operational    Int      @default(0)
  compliance     Int      @default(0)
  financial      Int      @default(0)
  flagsJson      String   @default("[]")
  clusterSize    Int      @default(0)
  clusterAvgScore Float   @default(0)
  oosProb90d     Float?
  trend          String   @default("STABLE")
  updatedAt      DateTime @updatedAt

  @@index([overallScore])
  @@index([grade])
}

// ── Continuous Monitoring SaaS ──────────────────────────────────

model Subscription {
  id                    String   @id @default(cuid())
  userId                String   @unique
  tier                  String
  status                String   @default("active")
  stripeSubscriptionId  String   @unique
  stripePriceId         String
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  cancelAtPeriodEnd     Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MonitoredRoster {
  id        String          @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  carriers  RosterCarrier[]

  @@index([userId])
}

model RosterCarrier {
  id            String          @id @default(cuid())
  rosterId      String
  dotNumber     String
  legalName     String
  healthStatus  String          @default("unknown")
  lastGrade     String?
  lastScore     Int?
  lastCheckedAt DateTime?
  createdAt     DateTime        @default(now())
  roster        MonitoredRoster @relation(fields: [rosterId], references: [id], onDelete: Cascade)

  @@unique([rosterId, dotNumber])
  @@index([rosterId])
}

model MonitoringAlert {
  id            String    @id @default(cuid())
  userId        String
  dotNumber     String
  legalName     String
  alertType     String
  severity      String
  title         String
  detail        String
  previousValue String?
  newValue      String?
  readAt        DateTime?
  createdAt     DateTime  @default(now())
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

// ── Community Risk Reports ──────────────────────────────────────

model CommunityReport {
  id          String   @id @default(cuid())
  userId      String
  dotNumber   String
  reportType  String
  description String
  severity    String
  status      String   @default("active")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([dotNumber, createdAt])
  @@index([dotNumber, status])
  @@index([userId, dotNumber, reportType])
}

model CommunityReportSummary {
  dotNumber       String   @id @unique
  totalReports12m Int      @default(0)
  reportsByType   String   @default("{}")
  communityScore  Int      @default(0)
  isFlagged       Boolean  @default(false)
  lastReportAt    DateTime?
  updatedAt       DateTime @updatedAt
}

// ── API Key Usage Tracking ──────────────────────────────────────

model ApiKeyUsage {
  id        String   @id @default(cuid())
  tokenId   String
  endpoint  String
  dotNumber String?
  createdAt DateTime @default(now())
  token     ApiToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)

  @@index([tokenId, createdAt])
}
