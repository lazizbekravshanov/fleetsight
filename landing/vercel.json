{
  "framework": "nextjs",
  "installCommand": "npm install",
  "buildCommand": "npx prisma generate && npx prisma db push --accept-data-loss && npm run build",
  "crons": [
    {
      "path": "/api/cron/watchlist-check",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/roster-check",
      "schedule": "0 6 * * *"
    }
  ]
}
